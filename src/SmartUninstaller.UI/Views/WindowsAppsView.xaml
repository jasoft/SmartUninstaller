<UserControl x:Class="SmartUninstaller.UI.Views.WindowsAppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Windows 应用" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding AppCount, StringFormat=' ({0} 个)'}" FontSize="14" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <Button Content="🔄 扫描" Command="{Binding ScanCommand}" Margin="20,0,0,0" Padding="10,5" Cursor="Hand"/>
            <Button Content="🗑️ 卸载选中" Command="{Binding UninstallSelectedCommand}" Margin="10,0,0,0" Padding="10,5" Cursor="Hand"
                    Background="#F44336" Foreground="White"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding AppList}" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectedItem="{Binding SelectedApp}" BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay}" Header="选择" Width="50"/>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="100"/>
                <DataGridTextColumn Header="发布者" Binding="{Binding Publisher}" Width="150"/>
                <DataGridTextColumn Header="安装路径" Binding="{Binding InstallPath}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
