<UserControl x:Class="SmartUninstaller.UI.Views.InstalledSoftwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SmartUninstaller.UI.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="已安装软件" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SoftwareCount, StringFormat=' ({0} 个)'}" FontSize="14" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <Button Content="🔄 刷新" Command="{Binding RefreshCommand}" Margin="20,0,0,0" Padding="10,5" Cursor="Hand"/>
            <Button Content="🔍 全选" Command="{Binding SelectAllCommand}" Margin="10,0,0,0" Padding="10,5" Cursor="Hand"/>
            <Button Content="取消全选" Command="{Binding DeselectAllCommand}" Margin="5,0,0,0" Padding="10,5" Cursor="Hand"/>
            <Button Content="🗑️ 卸载选中" Command="{Binding UninstallSelectedCommand}" Margin="20,0,0,0" Padding="10,5" Cursor="Hand" 
                    Background="#F44336" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- 搜索栏 -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Padding="5">
            <Grid>
                <TextBlock Text="输入关键词搜索软件..." Foreground="Gray" VerticalAlignment="Center" Margin="5,0"
                           Visibility="{Binding IsSearchEmpty, Converter={StaticResource BoolToVis}}"/>
                <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         BorderThickness="0" Background="Transparent" FontSize="14" Padding="3"/>
            </Grid>
        </Border>

        <!-- 软件列表 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredSoftwareList}" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Extended" CanUserSortColumns="True"
                  SelectedItem="{Binding SelectedSoftware}"
                  BorderBrush="#E0E0E0" RowBackground="White" AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay}" Header="选择" Width="50"/>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="100"/>
                <DataGridTextColumn Header="发布者" Binding="{Binding Publisher}" Width="150"/>
                <DataGridTextColumn Header="大小" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="80"/>
                <DataGridTextColumn Header="安装日期" Binding="{Binding InstallDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridCheckBoxColumn Binding="{Binding IsPortable}" Header="便携" Width="50"/>
                <DataGridCheckBoxColumn Binding="{Binding IsRunning}" Header="运行中" Width="50"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="卸载" Command="{Binding UninstallSelectedCommand}"/>
                    <Separator/>
                    <MenuItem Header="查看详情" Command="{Binding ViewDetailsCommand}"/>
                    <MenuItem Header="打开安装目录" Command="{Binding OpenInstallPathCommand}"/>
                    <MenuItem Header="扫描残留" Command="{Binding ScanLeftoversCommand}"/>
                    <Separator/>
                    <MenuItem Header="强制卸载" Command="{Binding ForceUninstallCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- 底部信息 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{Binding SelectedCount, StringFormat='已选择 {0} 个软件'}" Foreground="Gray"/>
            <TextBlock Text="{Binding TotalSize, StringFormat='  |  总大小: {0}'}" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</UserControl>
