<UserControl x:Class="SmartUninstaller.UI.Views.LeftoversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SmartUninstaller.UI.Converters">
    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="残留清理" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding LeftoverCount, StringFormat=' ({0} 项)'}" FontSize="14" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <Button Content="🔍 扫描残留" Command="{Binding ScanCommand}" Margin="20,0,0,0" Padding="10,5" Cursor="Hand"/>
            <Button Content="🗑️ 清理选中" Command="{Binding CleanSelectedCommand}" Margin="10,0,0,0" Padding="10,5" Cursor="Hand"
                    Background="#F44336" Foreground="White"/>
            <ProgressBar Value="{Binding ProgressValue}" Width="200" Height="20" Margin="20,0,0,0" 
                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding LeftoverList}" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectedItem="{Binding SelectedLeftover}" BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay}" Header="选择" Width="50"/>
                <DataGridTextColumn Header="软件名称" Binding="{Binding SoftwareName}" Width="150"/>
                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="路径" Binding="{Binding Path}" Width="*"/>
                <DataGridTextColumn Header="大小" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="80"/>
                <DataGridTextColumn Header="置信度" Binding="{Binding ConfidenceScore, StringFormat=P0}" Width="70"/>
                <DataGridTextColumn Header="风险等级" Binding="{Binding RiskDescription}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{Binding TotalSizeText}" Foreground="Gray"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
