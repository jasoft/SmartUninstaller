<Window x:Class="SmartUninstaller.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SmartUninstaller.UI.Views"
        xmlns:viewModels="clr-namespace:SmartUninstaller.UI.ViewModels"
        Title="SmartUninstaller" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📦 SmartUninstaller" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="设置" Style="{DynamicResource FlatButton}"
                            Command="{Binding OpenSettingsCommand}" Margin="5,0" />
                    <Button Content="关于" Style="{DynamicResource FlatButton}"
                            Command="{Binding OpenAboutCommand}" Margin="5,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 侧边栏导航 -->
            <Border Grid.Column="0" Background="{DynamicResource SecondaryBrush}">
                <StackPanel>
                    <RadioButton Content="📦 已安装软件" Style="{DynamicResource NavigationRadioButton}"
                                 IsChecked="True" Command="{Binding NavigateToInstalledCommand}" />
                    <RadioButton Content="💼 便携软件" Style="{DynamicResource NavigationRadioButton}"
                                 Command="{Binding NavigateToPortableCommand}" />
                    <RadioButton Content="🗑️ 残留清理" Style="{DynamicResource NavigationRadioButton}"
                                 Command="{Binding NavigateToLeftoversCommand}" />
                    <RadioButton Content="🔌 浏览器扩展" Style="{DynamicResource NavigationRadioButton}"
                                 Command="{Binding NavigateToExtensionsCommand}" />
                    <RadioButton Content="🪟 Windows应用" Style="{DynamicResource NavigationRadioButton}"
                                 Command="{Binding NavigateToWindowsAppsCommand}" />
                    <RadioButton Content="💾 备份管理" Style="{DynamicResource NavigationRadioButton}"
                                 Command="{Binding NavigateToBackupCommand}" />
                    <RadioButton Content="🧹 系统清理" Style="{DynamicResource NavigationRadioButton}"
                                 Command="{Binding NavigateToCleanupCommand}" />
                </StackPanel>
            </Border>

            <!-- 内容区域 -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" />
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="{DynamicResource SecondaryBrush}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                    <ProgressBar Value="{Binding ProgressValue}" Width="200" Height="20"
                                 Margin="10,0" Visibility="{Binding IsProgressVisible}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="版本 1.0.0" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
