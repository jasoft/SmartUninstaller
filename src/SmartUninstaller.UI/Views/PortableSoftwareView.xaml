<UserControl x:Class="SmartUninstaller.UI.Views.PortableSoftwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SmartUninstaller.UI.Converters">
    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="便携软件" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SoftwareCount, StringFormat=' ({0} 个)'}" FontSize="14" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <Button Content="🔄 扫描" Command="{Binding ScanCommand}" Margin="20,0,0,0" Padding="10,5" Cursor="Hand"/>
            <Button Content="🗑️ 删除选中" Command="{Binding DeleteSelectedCommand}" Margin="10,0,0,0" Padding="10,5" Cursor="Hand"
                    Background="#F44336" Foreground="White"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding SoftwareList}" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectedItem="{Binding SelectedSoftware}" BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay}" Header="选择" Width="50"/>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="100"/>
                <DataGridTextColumn Header="路径" Binding="{Binding InstallPath}" Width="300"/>
                <DataGridTextColumn Header="大小" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="80"/>
                <DataGridCheckBoxColumn Binding="{Binding IsRunning}" Header="运行中" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</UserControl>
